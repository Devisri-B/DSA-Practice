{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++ (Active File)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-O2",
                "${file}",
                "-o",
                "${workspaceFolder}/bin/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "showReuseMessage": true
            }
        },
        {
            "label": "Run C++ (Active File)",
            "type": "shell",
            "command": "${workspaceFolder}/bin/${fileBasenameNoExtension}",
            "dependsOn": "Build C++ (Active File)",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always"
            }
        },
        {
            "label": "Python: Run (Active File)",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "${file}"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always"
            }
        },
        {
            "label": "Python: Activate Venv",
            "type": "shell",
            "command": "source ${workspaceFolder}/venv/bin/activate && python --version",
            "presentation": {
                "echo": true,
                "reveal": "always"
            }
        },
        {
            "label": "Jupyter Notebook",
            "type": "shell",
            "command": "source ${workspaceFolder}/venv/bin/activate && jupyter notebook",
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always"
            }
        },
        {
            "label": "Clean Build Artifacts",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "presentation": {
                "echo": true,
                "reveal": "always"
            }
        }
    ]
}
